from Compiler.types import sfix, sint
from Compiler.library import for_range

sfix.set_precision(32, 32)

# Possible local-version note:
# Some MP-SPDZ releases provide higher-level ml layers for conv/relu.
# This skeleton uses explicit loops because assignment emphasizes core secure
# multiplication and secure ReLU logic.


def relu_scalar(x):
    return x * (x > 0)


